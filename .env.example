# Sepolia (optional — only if deploying with --network sepolia)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...

# Deploy script (scripts/deploy.ts)
# Leave empty on local Hardhat network to deploy a mock ERC20 as collateral.
USDT_ADDRESS=
# Optional extra admin (receives MARKET_ADMIN + RESOLVER alongside deployer)
ADMIN_ADDRESS=

# Optional ERC1155 metadata base URI for deploy script
BASE_URI=
